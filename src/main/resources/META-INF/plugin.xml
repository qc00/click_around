<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>software.nmr.click_around</id>

    <!-- Public plugin name should be written in Title Case.
     Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>Click_around</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor>Click Around</vendor>

    <description><![CDATA[
        Navigate from XML element names and attribute values to Java classes and methods
        annotated with configurable annotations.
        ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
                serviceImplementation="software.nmr.click_around.settings.AppSettings"/>

        <applicationConfigurable
                groupId="editor"
                instance="software.nmr.click_around.settings.UI"
                id="software.nmr.click_around.settings.app"
                displayName="Click Around"/>
        <projectConfigurable
                groupId="editor"
                instance="software.nmr.click_around.settings.UI"
                id="software.nmr.click_around.settings"
                nonDefaultProject="true"
                displayName="Click Around (Project)"/>

        <gotoDeclarationHandler
                implementation="software.nmr.click_around.handlers.GotoHandler"/>
    </extensions>
    
</idea-plugin>
